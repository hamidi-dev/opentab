    def _model_table(self, rows: list[tuple], title: str, width: int) -> list[str]:
        # rows: (name, runs, cost, tokens, cache_read, cache_write, output). The
        # model column fits the longest name (so the numbers sit right after it),
        # capped by the available width so long names aren't cut when there's room.
        longest = max([len(str(r[0])) for r in rows] + [len("Model")])
        mw = min(longest, max(20, width - 61))
        total_cost = sum(float(r[2]) for r in rows)
        lines = [
            title,
            f"{'Model':{mw}} {'Msgs':>4} {'Cost':>10} {'Share':>5} {'Tokens':>9} {'CacheR':>9} {'CacheW':>9} {'Output':>8}",
        ]
        for name, runs, cost, tok, cr, cw, out in rows:
            lines.append(
                f"{shorten(name, mw):{mw}} {int(runs):>4} {money(float(cost)):>10} "
                f"{pct(float(cost), total_cost):>5} "
                f"{human_tokens(int(tok)):>9} {human_tokens(int(cr)):>9} {human_tokens(int(cw)):>9} {human_tokens(int(out)):>8}"
            )
        if any(str(name).startswith("unknown") for name, *_ in rows):
            lines.extend(
                [
                    "",
                    "! unknown (not recorded) means provider/model metadata was not stored for these rows.",
                ]
            )
        return lines

    def _top_models(self, rows: list[tuple], width: int) -> list[str]:
        # rows: (name, cost, tokens, runs). Compact list under "# Top Models".
        if not rows:
            return []
        mw = min(max(len(str(r[0])) for r in rows), max(20, width - 37))
        total_cost = sum(float(r[1]) for r in rows)
        return [
            f"{shorten(name, mw):{mw}} {money(float(cost)):>10} {pct(float(cost), total_cost):>5} "
            f"{human_tokens(int(tok)):>8} msgs {int(runs)}"
            for name, cost, tok, runs in rows
        ]

    @staticmethod
    def _agg_rows(aggregate: list[tuple[str, dict]]) -> list[tuple]:
        return [
            (
                m,
                it["runs"],
                it["cost"],
                it["tokens"],
                it["cache_read"],
                it["cache_write"],
                it["output"],
            )
            for m, it in aggregate
        ]

    @staticmethod
    def _mix_rows(model_rows: list[dict]) -> list[tuple]:
        return [
            (
                r["model_name"],
                r["runs"],
                r["cost"],
                r["tokens_total"],
                r["cache_read"],
                r["cache_write"],
                r["output"],
            )
            for r in model_rows
        ]

    def month_overview(self, month: MonthSummary, width: int) -> list[str]:
        lines = [
            "# Monthly Insight",
            f"Month:           {month.month}",
            f"Cost:            {money(month.cost)}",
            f"Share of range:  {pct(month.cost, self.range_cost_total())}",
            f"Tokens:          {tokens(month.tokens)}",
            f"Sessions:        {month.workflows}",
            f"Subagents:       {month.subagents}",
            f"Unpriced tokens: {tokens(month.unpriced_tokens)}",
        ]
        if month.unpriced_tokens:
            lines.extend(
                [
                    "",
                    "! Some tokens have local cost = $0.00. Copilot billing may still charge account credits.",
                ]
            )
        month_ws = self.workflows_for_month(month.month)
        by_day: dict[str, float] = defaultdict(float)
        for w in month_ws:
            by_day[w.created_at[:10]] += w.total_cost
        ndays = calendar.monthrange(int(month.month[:4]), int(month.month[5:7]))[1]
        series = [by_day.get(f"{month.month}-{d:02d}", 0.0) for d in range(1, ndays + 1)]
        lines.extend(["", "# Daily Trend", sparkline(series)])
        if by_day:
            peak_day = max(by_day, key=by_day.get)
            lines.append(f"days 1–{ndays}   peak {money(by_day[peak_day])} on {peak_day}")
        lines.extend(["", "# Top Models"])
        agg = self.aggregate_models(month_ws)
        lines.extend(
            self._top_models([(m, it["cost"], it["tokens"], it["runs"]) for m, it in agg], width)
        )
        lines.extend(["", "# Top Sessions"])
        for workflow in self.top_sessions(month_ws):
            lines.append(
                f"{money(workflow.total_cost):>10} {pct(workflow.total_cost, month.cost):>5} "
                f"{human_tokens(workflow.total_tokens):>8} "
                f"agents {workflow.subagents:<3} {shorten(workflow.title, max(20, width - 37))}"
            )
        return lines

    def month_models(self, month: MonthSummary, width: int) -> list[str]:
        agg = self.aggregate_models(self.workflows_for_month(month.month))
        return self._model_table(self._agg_rows(agg), "# Monthly Model Spend", width)

