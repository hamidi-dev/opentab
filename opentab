# Blended $/token used to price sessions OpenCode recorded with no cost
# (e.g. credit-based providers). Tuned so a few-million-token session lands in a
# believable single-digit-dollar range.
DEMO_RATE = 1.6e-6
# Local models (ollama, lmstudio, ...) get remapped to recognizable cloud models
# in demo mode, so screenshots show a clean, relatable provider/model mix instead
# of whatever local tags you happen to run. Deterministic per source name.
DEMO_LOCAL_PROVIDERS = ("ollama", "lmstudio", "llamacpp", "local")
DEMO_MODEL_POOL = (
    "anthropic/claude-opus-4.6",
    "anthropic/claude-sonnet-4.5",
