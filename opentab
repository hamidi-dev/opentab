    def _model_table(self, rows: list[tuple], title: str, width: int) -> list[str]:
        # rows: (name, runs, cost, tokens, cache_read, cache_write, output). The
        # model column fits the longest name (so the numbers sit right after it),
        # capped by the available width so long names aren't cut when there's room.
        longest = max([len(str(r[0])) for r in rows] + [len("Model")])
        mw = min(longest, max(20, width - 61))
        total_cost = sum(float(r[2]) for r in rows)
        lines = [
            title,
            f"{'Model':{mw}} {'Msgs':>4} {'Cost':>10} {'Share':>5} {'Tokens':>9} {'CacheR':>9} {'CacheW':>9} {'Output':>8}",
        ]
        for name, runs, cost, tok, cr, cw, out in rows:
            lines.append(
                f"{shorten(name, mw):{mw}} {int(runs):>4} {money(float(cost)):>10} "
                f"{pct(float(cost), total_cost):>5} "
                f"{human_tokens(int(tok)):>9} {human_tokens(int(cr)):>9} {human_tokens(int(cw)):>9} {human_tokens(int(out)):>8}"
            )
        if any(str(name).startswith("unknown") for name, *_ in rows):
            lines.extend(
                [
                    "",
                    "! unknown (not recorded) means provider/model metadata was not stored for these rows.",
                ]
            )
        return lines

    @staticmethod
    def _agg_rows(aggregate: list[tuple[str, dict]]) -> list[tuple]:
        return [
            (
                m,
                it["runs"],
                it["cost"],
                it["tokens"],
                it["cache_read"],
                it["cache_write"],
                it["output"],
            )
            for m, it in aggregate
        ]

    @staticmethod
    def _mix_rows(model_rows: list[dict]) -> list[tuple]:
        return [
            (
                r["model_name"],
                r["runs"],
                r["cost"],
                r["tokens_total"],
                r["cache_read"],
                r["cache_write"],
                r["output"],
            )
            for r in model_rows
        ]

