    def range_label(self) -> str:
        if self.custom_since or self.custom_until:
            label = f"since {self.custom_since}" if self.custom_since else "from start"
            if self.custom_until:
                label += f" until {self.custom_until}"
            return label
        if self.range_days is None:
            return "all time"
        return f"last {self.range_days} days"

    def box(self, stdscr: curses.window, y: int, x: int, h: int, w: int, title: str) -> None:
        if h <= 1 or w <= 1:
            return
        stdscr.addch(y, x, curses.ACS_ULCORNER)
        stdscr.addch(y, x + w - 1, curses.ACS_URCORNER)
        stdscr.addch(y + h - 1, x, curses.ACS_LLCORNER)
        stdscr.addch(y + h - 1, x + w - 1, curses.ACS_LRCORNER)
        stdscr.hline(y, x + 1, curses.ACS_HLINE, w - 2)
        stdscr.hline(y + h - 1, x + 1, curses.ACS_HLINE, w - 2)
        stdscr.vline(y + 1, x, curses.ACS_VLINE, h - 2)
        stdscr.vline(y + 1, x + w - 1, curses.ACS_VLINE, h - 2)
        self.write(
            stdscr, y, x + 2, f" {shorten(title, w - 6)} ", curses.color_pair(1) | curses.A_BOLD
        )

    def hline(self, stdscr: curses.window, y: int, x: int, w: int) -> None:
        stdscr.hline(y, x, curses.ACS_HLINE, max(0, w - 1))

    def write(self, stdscr: curses.window, y: int, x: int, text: str, attr: int = 0) -> None:
        height, width = stdscr.getmaxyx()
        if y < 0 or y >= height or x < 0 or x >= width:
            return
        try:
            stdscr.addstr(y, x, text[: max(0, width - x - 1)], attr)
        except curses.error:
            pass

    def write_rich(self, stdscr: curses.window, y: int, x: int, text: str, attr: int = 0) -> None:
        self.write(stdscr, y, x, text, attr)
        if attr & curses.A_BOLD and text.startswith("# "):
            return
        for match in MONEY_PATTERN.finditer(text):
            self.write(
                stdscr, y, x + match.start(), match.group(0), curses.color_pair(3) | curses.A_BOLD
            )
        for match in TOKEN_PATTERN.finditer(text):
            token_text = match.group(0)
            self.write(stdscr, y, x + match.start(), token_text, self.token_attr(token_text))


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog="opentab", description="opentab — OpenCode spend TUI")
    parser.add_argument("--db", default=os.path.expanduser("~/.local/share/opencode/opencode.db"))
    parser.add_argument(
        "--days",
        type=int,
        default=None,
        help="initial range in days (default: all time; change live with [ ])",
    )
    parser.add_argument("--since")
    parser.add_argument("--until")
    parser.add_argument(
        "--demo",
        action="store_true",
        help="anonymize titles/paths and backfill synthetic prices "
        "(for live demos and screenshots; never writes to the DB)",
    )
    return parser.parse_args()


MIN_PYTHON = (3, 9)


def main() -> int:
    if sys.version_info < MIN_PYTHON:
        raise SystemExit(
            f"opentab requires Python {MIN_PYTHON[0]}.{MIN_PYTHON[1]}+ "
            f"(found {sys.version_info[0]}.{sys.version_info[1]})."
        )
    args = parse_args()  # handles --help first, so it works even without curses
    if curses is None:
        raise SystemExit(
            "opentab needs Python's curses module, which is not available on native Windows.\n"
            "  - Recommended: run opentab under WSL (where OpenCode's database usually lives anyway).\n"
            "  - Or on native Windows: pip install windows-curses (untested)."
        )
    if not os.path.exists(args.db):
        raise SystemExit(f"OpenCode database not found: {args.db}")
    store = Store(args.db, args)
    app = App(store, args)
    curses.wrapper(app.run)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
