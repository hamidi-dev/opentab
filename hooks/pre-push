#!/usr/bin/env sh
set -eu

set -- opentab test_opentab.py

if command -v python3 >/dev/null 2>&1; then
  python_cmd=python3
elif command -v python >/dev/null 2>&1; then
  python_cmd=python
else
  printf '%s\n' "pre-push: python3/python is not installed" >&2
  exit 1
fi

if ! command -v ruff >/dev/null 2>&1; then
  printf '%s\n' "pre-push: ruff is not installed. Install with: pip install ruff==0.1.15" >&2
  exit 1
fi

printf '%s\n' "pre-push: ruff check"
ruff check "$@"

printf '%s\n' "pre-push: ruff format --check"
ruff format --check "$@"

printf '%s\n' "pre-push: py_compile"
"$python_cmd" -m py_compile opentab

printf '%s\n' "pre-push: unit tests"
"$python_cmd" test_opentab.py

if command -v shellcheck >/dev/null 2>&1; then
  printf '%s\n' "pre-push: shellcheck"
  shellcheck install.sh hooks/pre-push
else
  printf '%s\n' "pre-push: shellcheck not installed; skipping" >&2
fi
